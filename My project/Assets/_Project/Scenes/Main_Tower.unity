    - target: {fileID: 3107209517948532123, guid: a4211a8d61683b84786a4bcace11bf79, type: 3}
      propertyPath: 'pages.Array.data[0]'
      value: "         \u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E
        \u0434\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440\u0430\n\u0412 \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438
        \u0434\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440\u0430 \u0432\u0445\u043E\u0434\u0438\u0442:\n1)
        \u041A\u043E\u0440\u0440\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u043A\u0430
        \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u043E\u0432 \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u0432,
        \u043F\u0440\u043E\u043B\u0435\u0442\u0430\u044E\u0449\u0438\u0445 \u0432
        \u043F\u043E\u0434\u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u043E\u0439
        \u0437\u043E\u043D\u0435 \u0434\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440\u0430\n2)
        \u041F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
        \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u0432\n3) \u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430
        \u0441\u0432\u044F\u0437\u0438 \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
        \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F\u043C\u0438 \u0441
        \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0442\u0430\u0446\u0438\u043E\u043D\u0430\u0440\u043D\u043E\u0433\u043E
        \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u0430 \u0432 \u0434\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440\u0441\u043A\u043E\u0439
        \u0431\u0430\u0448\u043D\u0435.\n"
      objectReference: {fileID: 0}
    - target: {fileID: 3107209517948532123, guid: a4211a8d61683b84786a4bcace11bf79, type: 3}
      propertyPath: 'pages.Array.data[1]'
      value: "             \u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0440\u0430\u0434\u0430\u0440\u0430\n\u041A\u0430\u0436\u0434\u044B\u0439
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442, \u043F\u043E\u044F\u0432\u0438\u0432\u0448\u0438\u0439\u0441\u044F
        \u0432 \u043F\u043E\u0434\u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u043E\u0439
        \u0437\u043E\u043D\u0435 \u0434\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440\u0430
        \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u0430
        \u0420\u0410\u0414\u0410\u0420\u0415.\n\u041D\u0430\u0436\u0430\u0432 \u043D\u0430
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442, \u0431\u0443\u0434\u0435\u0442
        \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
        \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F: \u0442\u0435\u043A\u0443\u0449\u0430\u044F
        \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u0430
        \u0438 \u0437\u043E\u043D\u0430, \u043A\u0443\u0434\u0430 \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u043E\u043C\u0443
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u0443 \u043D\u0443\u0436\u043D\u043E
        \u043F\u0440\u0438\u0431\u044B\u0442\u044C.\n\n\u0415\u0441\u043B\u0438 \u0422\u0420\u0410\u0415\u041A\u0422\u041E\u0420\u0418\u042F
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u0430 \u043D\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
        \u0441 \u0442\u0440\u0435\u0431\u0443\u0435\u043C\u043E\u0439 \u0417\u041E\u041D\u041E\u0419
        \u041F\u0420\u0418\u0411\u042B\u0422\u0418\u042F, \u0437\u0430\u0433\u043E\u0440\u0438\u0442\u0441\u044F
        \u0416\u0415\u041B\u0422\u042B\u0419 \u0418\u041D\u0414\u0418\u041A\u0410\u0422\u041E\u0420
        \u043D\u0430 \u043F\u0430\u043D\u0435\u043B\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.\n\n\u041A\u043E\u0433\u0434\u0430
        \u0441\u0430\u043C\u043E\u043B\u0435\u0442 \u0443\u0445\u043E\u0434\u0438\u0442
        \u0438\u0437 \u0432\u0430\u0448\u0435\u0439 \u0437\u043E\u043D\u044B \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F,
        \u044D\u0442\u043E \u0441\u043E\u0431\u044B\u0442\u0438\u0435 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u0435\u0442\u0441\u044F
        \u0417\u0415\u041B\u0415\u041D\u042B\u041C \u0418\u041D\u0414\u0418\u041A\u0410\u0422\u041E\u0420\u041E\u041C."
      objectReference: {fileID: 0}
    - target: {fileID: 3107209517948532123, guid: a4211a8d61683b84786a4bcace11bf79, type: 3}
      propertyPath: 'pages.Array.data[2]'
      value: "         \u0418\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0439\n\u041F\u043E\u0440\u044F\u0434\u043E\u043A
        \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044F
        \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438 \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u0430:\n1)
        \u041D\u0430\u0441\u0442\u0440\u043E\u0439\u0442\u0435\u0441\u044C \u043D\u0430
        \u043D\u043E\u043C\u0435\u0440 \u0440\u0435\u0439\u0441\u0430 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
        \u041F\u0423\u041B\u042C\u0422\u0410 \u0420\u0410\u0426\u0418\u0418 \u0441\u043B\u0435\u0432\u0430
        \u043E\u0442 \u0440\u0430\u0434\u0430\u0440\u0430\n2) \u0412 \u0440\u0430\u0434\u0430\u0440\u0435
        \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0430\u043C\u043E\u043B\u0435\u0442
        \u0438, \u0437\u0430\u0436\u0430\u0432 \u043A\u0443\u0440\u0441\u043E\u0440
        \u043D\u0430 \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u0435, \u043F\u0440\u043E\u043A\u0440\u0443\u0442\u0438\u0442\u0435
        \u043A\u043E\u043B\u0435\u0441\u043E \u043C\u044B\u0448\u0438, \u0432\u044B\u0431\u0440\u0430\u0432
        \u043D\u043E\u0432\u043E\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
        \u0434\u043B\u044F \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u0432.\n3)
        \u0421\u0432\u044F\u0436\u0438\u0442\u0435\u0441\u044C \u0441 \u044D\u043A\u0438\u043F\u0430\u0436\u0435\u043C,
        \u043D\u0430\u0436\u0430\u0432 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
        \u201C\u043A\u043E\u043D\u0442\u0430\u043A\u0442\u201D.\n4) \u041F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435
        \u043D\u0430 \u0440\u0430\u0434\u0430\u0440\u0435, \u0447\u0442\u043E \u0441\u0430\u043C\u043E\u043B\u0435\u0442
        \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044E.\n"
      objectReference: {fileID: 0}
    - target: {fileID: 3107209517948532123, guid: a4211a8d61683b84786a4bcace11bf79, type: 3}
      propertyPath: 'pages.Array.data[3]'
      value: "        \u0423\u0434\u043E\u0431\u0441\u0442\u0432\u0430 \u0434\u043B\u044F
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432\n\u041C\u044B
        \u0437\u0430 \u0442\u043E \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0448\u0438\u043C
        \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430\u043C \u0431\u044B\u043B\u043E
        \u043A\u043E\u0444\u043C\u043E\u0440\u0442\u043D\u043E, \u0432\u0435\u0434\u044C
        \u044D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
        \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0431\u043E\u043B\u0435\u0435
        \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
        \u043C\u044B \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u043C
        \u0431\u0435\u0437\u043B\u0438\u043C\u0438\u0442\u043D\u044B\u0439 \u0437\u0430\u043F\u0430\u0441
        \u043A\u043E\u0444\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u044B
        \u043D\u0430\u0439\u0442\u0438 \u043D\u0430 \u043A\u0443\u0445\u043D\u0435.\n"
      objectReference: {fileID: 0}
